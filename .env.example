# 数据库
DB_PASSWORD=change_me_please

# JWT
JWT_SECRET_KEY=change_me_to_a_random_secret_key_at_least_32_chars

# DeepSeek API（全局默认，用户可自行覆盖）
# 注意：每个用户应配置自己的 API Key，此处仅用于系统级操作
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 数据存储目录（Docker 卷映射的宿主机路径）
# 默认为 ./data，可改为绝对路径如 /mnt/data 或 d:/docker-data
# DATA_DIR=./data
