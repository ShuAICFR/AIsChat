# 数据库
DB_PASSWORD=change_me_please

# JWT
JWT_SECRET_KEY=change_me_to_a_random_secret_key_at_least_32_chars

# DeepSeek API（全局默认，用户可自行覆盖）
# 注意：每个用户应配置自己的 API Key，此处仅用于系统级操作
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 联邦通信 — GitHub 注册表（可选，仅"一键注册公网 ID"功能需要）
# 在 https://github.com/settings/tokens 生成 Fine-grained token，需要仓库读写权限
# GITHUB_TOKEN=github_pat_xxxxxxxxxxxx
# 注册表仓库和文件路径（默认值通常无需修改）
# REGISTRY_REPO=ShuAICFR/AIsChat
# REGISTRY_FILE=federation-registry.json

# 数据存储目录（Docker 卷映射的宿主机路径）
# 默认为 ./data，可改为绝对路径如 /mnt/data 或 d:/docker-data
# DATA_DIR=./data
